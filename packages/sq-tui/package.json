{
  "name": "@allen-heath-sq-tools/tui",
  "version": "0.1.1",
  "type": "module",
  "description": "Terminal UI for Allen & Heath SQ consoles",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sq-tui": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@allen-heath-sq-tools/api": "*",
    "ink": "^7.0.5",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
