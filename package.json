{
  "name": "allen-heath-sq-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial tools for Allen & Heath SQ digital mixing consoles",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=packages/sq-api",
    "build:tui": "npm run build --workspace=packages/sq-tui",
    "build:osc": "cd packages/sq-osc && deno task bundle",
    "build:osc:windows": "cd packages/sq-osc && deno task bundle:windows",
    "build:osc:linux": "cd packages/sq-osc && deno task bundle:linux",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build --workspaces --if-present && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0"
  },
  "license": "MIT"
}
